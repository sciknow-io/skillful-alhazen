# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Skill-mounted dashboard code (generated by make build-dashboard)
# Route groups and API dirs are gitignored but Turbopack needs to discover them.
# Individual skill entries are un-ignored so Turbopack follows symlinks for route discovery.
# The symlink targets (local_skills/*) are gitignored at the project root level.
src/app/(*)
!src/app/(jobhunt)
!src/app/(techrecon)
!src/app/(alg-precision-therapeutics)
src/app/api/*
!src/app/api/typedb-status
!src/app/api/jobhunt
!src/app/api/techrecon
!src/app/api/alg-precision-therapeutics
src/components/*
src/lib/*.ts
!src/lib/utils.ts
