# =============================================================================
# SKILLLOG NAMESPACE - TypeDB 2.x Schema
# =============================================================================
# Tracks skill invocations for token observability, evaluation, and TextGrad
# optimization. Logs are written by the PostToolUse Claude Code hook.
#
# Entity hierarchy:
#   skilllog-session    → collection     (groups invocations in one Claude session)
#   skilllog-invocation → domain-thing   (one skill command call)
#   skilllog-input      → artifact       (raw command + args)
#   skilllog-output     → artifact       (raw stdout/stderr)
# =============================================================================

define

# -----------------------------------------------------------------------------
# ATTRIBUTES
# -----------------------------------------------------------------------------

skill-name sub attribute, value string;
command-name sub attribute, value string;
session-id sub attribute, value string;
exit-code sub attribute, value long;
duration-ms sub attribute, value long;

# Token estimates (tiktoken cl100k_base encoding)
input-tokens-estimate sub attribute, value long;
output-tokens-estimate sub attribute, value long;
total-tokens-estimate sub attribute, value long;

# Evaluation label for TextGrad dataset building
# Values: unlabeled | golden | rejected
evaluation-label sub attribute, value string;


# -----------------------------------------------------------------------------
# ENTITY TYPES
# -----------------------------------------------------------------------------

# A Claude Code session — groups related invocations together.
# Stored as a collection for queryability across invocations.
skilllog-session sub collection,
    owns session-id;


# One recorded skill command execution.
skilllog-invocation sub domain-thing,
    owns skill-name,
    owns command-name,
    owns session-id,
    owns exit-code,
    owns duration-ms,
    owns input-tokens-estimate,
    owns output-tokens-estimate,
    owns total-tokens-estimate,
    owns evaluation-label;


# Raw command string + args captured as input artifact.
skilllog-input sub artifact;


# Raw stdout/stderr captured as output artifact.
skilllog-output sub artifact;
