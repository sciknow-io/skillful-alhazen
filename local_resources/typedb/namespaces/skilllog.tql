# =============================================================================
# SKILLLOG NAMESPACE - TypeDB 3.x Schema
# =============================================================================
# Tracks skill invocations and LLM calls for token observability, evaluation,
# and TextGrad optimization.
#
# Entity hierarchy:
#   skilllog-session    → collection     (groups invocations in one Claude session)
#   skilllog-invocation → domain-thing   (one skill command call, logged by Claude Code hook)
#   skilllog-input      → artifact       (raw command + args)
#   skilllog-output     → artifact       (raw stdout/stderr)
#   skilllog-llm-call   → domain-thing   (one LLM API round-trip, logged by LiteLLM callback)
# =============================================================================

define

# -----------------------------------------------------------------------------
# ATTRIBUTES
# -----------------------------------------------------------------------------

attribute skill-name, value string;
attribute command-name, value string;
attribute session-id, value string;
attribute exit-code, value integer;
attribute duration-ms, value integer;

# Token estimates (tiktoken cl100k_base encoding)
attribute input-tokens-estimate, value integer;
attribute output-tokens-estimate, value integer;
attribute total-tokens-estimate, value integer;
# Estimated tokens in always-loaded static context files (CLAUDE.md, SKILL.mds, etc.)
attribute context-tokens-estimate, value integer;
# Per-file breakdown of context tokens (stored since Feb 2026)
attribute claude-md-tokens, value integer;
attribute memory-md-tokens, value integer;
attribute skill-mds-tokens, value integer;
attribute soul-md-tokens, value integer;
attribute agents-md-tokens, value integer;

# Evaluation label for TextGrad dataset building
# Values: unlabeled | golden | rejected
attribute evaluation-label, value string;

# LLM call tracking (LiteLLM callback → OpenClaw usage)
attribute llm-model, value string;
attribute cost-usd, value double;
attribute cache-creation-tokens, value integer;
attribute cache-read-tokens, value integer;


# -----------------------------------------------------------------------------
# ENTITY TYPES
# -----------------------------------------------------------------------------

# A Claude Code session — groups related invocations together.
# Stored as a collection for queryability across invocations.
entity skilllog-session sub collection,
    owns session-id;


# One recorded skill command execution.
entity skilllog-invocation sub domain-thing,
    owns skill-name,
    owns command-name,
    owns session-id,
    owns exit-code,
    owns duration-ms,
    owns input-tokens-estimate,
    owns output-tokens-estimate,
    owns total-tokens-estimate,
    owns context-tokens-estimate,
    owns claude-md-tokens,
    owns memory-md-tokens,
    owns skill-mds-tokens,
    owns soul-md-tokens,
    owns agents-md-tokens,
    owns evaluation-label;


# Raw command string + args captured as input artifact.
entity skilllog-input sub artifact;


# Raw stdout/stderr captured as output artifact.
entity skilllog-output sub artifact;


# One LLM API round-trip logged by the LiteLLM callback (OpenClaw production).
# Written by local_resources/skilllog/litellm_callback.py via the MCP server's
# /log-llm-call HTTP endpoint.
entity skilllog-llm-call sub domain-thing,
    owns llm-model,
    owns session-id,
    owns input-tokens-estimate,
    owns output-tokens-estimate,
    owns cache-creation-tokens,
    owns cache-read-tokens,
    owns cost-usd,
    owns duration-ms,
    owns exit-code;


# -----------------------------------------------------------------------------
# SKILL QUALITY / SCHEMA GAP TRACKING
# -----------------------------------------------------------------------------
# Records deficiencies discovered during skill use - missing data, incorrect
# inferences, unclear workflows. Enables systematic skill improvement.

attribute gap-type, value string;
    # missing-user-context | missing-entity-type | missing-attribute
    # | unclear-workflow | incorrect-inference
attribute gap-severity, value string;
    # minor | moderate | significant
attribute gap-status, value string;
    # open | addressed | wont-fix
attribute gap-example, value string;
    # the specific triggering situation (verbatim or paraphrase)
attribute skill-version, value string;

# Skill model - represents a skill as a first-class trackable object.
# description (inherited) = what the skill does.
entity skill-model sub domain-thing,
    owns skill-name,
    owns skill-version,
    plays skill-has-gap:skill-model;

# Schema gap - a recorded deficiency in a skill's model.
# description (inherited) = what information is missing or wrong.
entity schema-gap sub domain-thing,
    owns gap-type,
    owns gap-severity,
    owns gap-status,
    owns gap-example,
    plays skill-has-gap:schema-gap;

relation skill-has-gap,
    relates skill-model,
    relates schema-gap;
