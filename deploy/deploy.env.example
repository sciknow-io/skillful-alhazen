# deploy.env.example — copy to deploy/deploy.env and fill in your values
# deploy.env is gitignored; this example file is safe to commit.

# --- Target ---
DEPLOY_TARGET=localhost          # IP address or 'localhost'
DEPLOY_TARGET_TYPE=macmini      # 'macmini' or 'vps'
DEPLOY_BRANCH=main              # git branch to deploy

# --- LLM ---
DEPLOY_PROVIDER=anthropic        # anthropic | openai | ollama | openai_compatible
DEPLOY_MODEL=claude-sonnet-4-6
DEPLOY_API_KEY=sk-ant-...

# --- Telegram ---
DEPLOY_TELEGRAM_TOKEN=           # from @BotFather
DEPLOY_TELEGRAM_USER=            # your Telegram user ID

# --- SSH ---
DEPLOY_ASK_PASS=true            # true = prompt for SSH/sudo password
# DEPLOY_SSH_USER=root
# DEPLOY_SSH_KEY=~/.ssh/id_rsa
